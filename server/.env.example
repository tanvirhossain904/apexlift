# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/apexlift
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/apexlift
MONGODB_URI=mongodb://localhost:27017/apexlift

# JWT secret — generate with: openssl rand -hex 48
JWT_SECRET=change_this_to_a_long_random_secret

# Server port (defaults to 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Comma-separated list of allowed origins for CORS.
# Dev default is Vite (http://localhost:5173). In production, set this
# to your deployed client URL, e.g. https://apexlift.app
CORS_ORIGIN=http://localhost:5173
